        "children": [
          {
            "type": "icon",
            "props": {
              "name": "FileBox",
              "color": "onPrimary",
              "size": 20
            }
          },
          {
            "type": "text",
            "props": {
              "content": {
                "en": "Generate Auto-Doc PDF",
                "tr": "PDF Raporu Üret"
              },
              "style": "buttonText"
            }
          }
        ]
      }
