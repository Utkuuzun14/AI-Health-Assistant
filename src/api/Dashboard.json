          },
          "accessibilityRole": "header",
          "accessibilityLabel": "Main Header"
        }
      },
      {
        "type": "weatherWidget",
        "props": {
          "style": "card",
          "elevation": 1,
          "accessibilityLabel": "Air Quality Widget",
          "mockValue": "Air Quality: 42 AQI (Good)",
          "mockPolen": "Pollen: Low"
        }
      },
      {
        "type": "card",
        "props": {
          "style": "aiCard",
          "elevation": 2,
          "accessibilityLabel": "Vitals Card"
